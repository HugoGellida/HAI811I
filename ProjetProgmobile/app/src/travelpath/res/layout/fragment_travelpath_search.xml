<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/travelpath_search_intro_title"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge" />

        <TextView
            android:id="@+id/travelpath_auth_status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/travelpath_search_signed_out"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/travelpath_search_budget_label"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge" />

        <EditText
            android:id="@+id/travelpath_budget_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/travelpath_search_budget_hint"
            android:inputType="number" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/travelpath_search_activity_label"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge" />

        <Spinner
            android:id="@+id/travelpath_activity_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/travelpath_search_place_label"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge" />

        <AutoCompleteTextView
            android:id="@+id/travelpath_place_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:completionThreshold="1"
            android:hint="@string/travelpath_search_place_hint"
            android:inputType="textCapWords" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/travelpath_search_duration_label"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge" />

        <Spinner
            android:id="@+id/travelpath_duration_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/travelpath_search_effort_label"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge" />

        <Spinner
            android:id="@+id/travelpath_effort_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/travelpath_search_outdoor_label"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge" />

        <Spinner
            android:id="@+id/travelpath_outdoor_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/travelpath_generate_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/travelpath_search_generate" />

        <TextView
            android:id="@+id/travelpath_search_status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/travelpath_routes_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:nestedScrollingEnabled="false" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>